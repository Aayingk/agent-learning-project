# ============================================
# LLM API Configuration
# ============================================

# OpenAI Configuration
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Ollama Configuration (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# GLM (智谱AI) Configuration
GLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash

# DeepSeek Configuration
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# Application Configuration
# ============================================

# Default LLM Provider (openai|anthropic|ollama)
DEFAULT_LLM_PROVIDER=openai

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# Streamlit
STREAMLIT_HOST=localhost
STREAMLIT_PORT=8501

# ============================================
# Storage Configuration
# ============================================

# ChromaDB (Vector Store)
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=agent_memory

# Session Storage (Short-term Memory)
SESSION_TTL=3600  # seconds

# ============================================
# Agent Configuration
# ============================================

# Context Window
MAX_CONTEXT_TOKENS=4000
MEMORY_SUMMARY_THRESHOLD=3000

# Tool Execution
TOOL_TIMEOUT=30  # seconds
MAX_TOOL_ITERATIONS=5

# RAG Configuration
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# ============================================
# Logging
# ============================================

LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ============================================
# Feature Flags
# ============================================

ENABLE_MULTI_AGENT=true
ENABLE_RAG=true
ENABLE_LONG_TERM_MEMORY=true
